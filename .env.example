# --- Backend ---
# Async connection string used by the FastAPI app.
# Host "db" is the docker-compose service name.
DATABASE_URL=postgresql+asyncpg://gophkeeper:gophkeeper@db:5432/gophkeeper

# Host port the API is published on (the container always listens on 8000).
# Set to 80 when deploying on the course VM so http://<vm> works directly.
API_PORT=8000

# --- PostgreSQL (must match the credentials inside DATABASE_URL) ---
POSTGRES_USER=gophkeeper
POSTGRES_PASSWORD=gophkeeper
POSTGRES_DB=gophkeeper
